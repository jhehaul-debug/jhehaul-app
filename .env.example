# ── Core ──────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Digital Ocean managed DB or docker-compose)
DATABASE_URL=postgresql://user:password@host:5432/jhehaul

# Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=your-secret-key-here

# The public base URL of your app (no trailing slash)
APP_BASE_URL=https://jhehaul.com

# Admin account email – this user gets is_admin=True on every startup
ADMIN_EMAIL=incorporateiq@gmail.com

# ── OAuth ─────────────────────────────────────────────────────────────────────
# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: https://jhehaul.com/auth/google/authorized
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
# Authorization callback URL: https://jhehaul.com/auth/github/authorized
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# Live secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Static payment links (Stripe Dashboard → Payment Links)
PAY_LINK_UNDER_150=https://buy.stripe.com/...
PAY_LINK_150_300=https://buy.stripe.com/...
PAY_LINK_OVER_300=https://buy.stripe.com/...
PAY_LINK_OVER_500=https://buy.stripe.com/...

# ── SendGrid ──────────────────────────────────────────────────────────────────
# API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-api-key-here

# "From" email address (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=noreply@jhehaul.com

# ── Twilio (optional – for SMS notifications) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567
